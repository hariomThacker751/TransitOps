{
  "name": "transitops-server",
  "version": "1.0.0",
  "description": "TransitOps — Express + MySQL backend (rules-driven fleet operations platform)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed:import": "node src/seeds/importCsv.js",
    "seed:users": "node src/seeds/seedUsers.js",
    "seed:all": "node src/seeds/importCsv.js --fresh && node src/seeds/seedUsers.js"
  },
  "keywords": [
    "transitops",
    "fleet",
    "express",
    "mysql"
  ],
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-validator": "^7.2.0",
    "fast-csv": "^5.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}