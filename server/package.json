{
  "name": "transitops-backend",
  "version": "1.0.0",
  "description": "TransitOps Fleet/Transport Operations Management Platform - Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup:db": "node src/seeds/setupDb.js",
    "seed:import": "node src/seeds/importCsv.js",
