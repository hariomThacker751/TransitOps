PORT=5000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=transitops_db
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:5173

# ── LLM (Sarvam AI) ───────────────────────────────────────────────────────
# Get a key from https://dashboard.sarvam.ai. Without LLM_API_KEY the LLM
# endpoints return a clear "not configured" error instead of failing.
LLM_PROVIDER=sarvam
LLM_API_KEY=YOUR_API_KEY
LLM_MODEL=sarvam-30b
LLM_BASE_URL=https://api.sarvam.ai
LLM_TIMEOUT_MS=30000
